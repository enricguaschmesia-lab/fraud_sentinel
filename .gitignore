__pycache__/
.pytest_cache/
.pytest_tmp/
pytest-cache-files-*/
.venv/
*.pyc
*.pyo
*.pyd

# Default-ignore generated binary and data-heavy outputs.
*.joblib
*.png
*.csv

# Track the repo artifacts required by the CLI, dashboard, and README.
artifacts/*
