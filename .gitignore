!artifacts/*.csv
!artifacts/*.json
!artifacts/*.joblib
!artifacts/figures/
!artifacts/figures/.gitkeep
!artifacts/figures/*.png

# Keep example CSV inputs synchronizable.
!examples/*.csv

outputs/

# The public training dataset is large and should stay out of normal git history.
data/raw/
data/processed/

